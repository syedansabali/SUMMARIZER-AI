rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Entity Validations ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['userId', 'filename', 'status']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.filename is string && data.filename.size() <= 255 &&
             data.status in ['uploading', 'parsing', 'extracting', 'indexing', 'completed', 'failed'] &&
             (data.get('progress', 0) is number) &&
             (data.get('message', '') is string) &&
             (data.get('text', '') is string) &&
             (data.get('chunks', []) is list);
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().uid == existing().uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['email', 'displayName', 'photoURL', 'updatedAt']);
    }

    match /documents/{docId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Client can create a blank job entry, but status is limited
      allow create: if isSignedIn() && 
                      isValidDocument(incoming()) &&
                      incoming().userId == request.auth.uid &&
                      incoming().status == 'uploading';
      
      // Only owner can update, limited fields (mostly metadata)
      // Note: Backend using Admin SDK will bypass these rules to update 'status', 'text', etc.
      allow update: if isOwner(existing().userId) && 
                      isValidDocument(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['filename', 'updatedAt']);
      
      allow delete: if isOwner(existing().userId);
    }

    match /chats/{chatId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      exists(/databases/$(database)/documents/documents/$(incoming().docId)) &&
                      get(/databases/$(database)/documents/documents/$(incoming().docId)).data.userId == request.auth.uid;
      
      allow update: if isOwner(existing().userId) &&
                      incoming().userId == existing().userId &&
                      incoming().docId == existing().docId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']);
      
      allow delete: if isOwner(existing().userId);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow list: if isSignedIn() && 
                    get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid &&
                      incoming().chatId == chatId &&
                      incoming().role in ['user', 'model'];
      
      allow delete: if false; // Messages are immutable for audit
    }
  }
}
