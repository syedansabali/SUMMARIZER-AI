{
  "version": 2,
  "buildCommand": "vite build && esbuild api/index.ts --bundle --platform=node --format=cjs --packages=external --outfile=api/index.cjs",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
