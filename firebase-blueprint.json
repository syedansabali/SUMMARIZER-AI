{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Document": {
      "title": "Document",
      "description": "Uploaded PDF document and its processing status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "filename": { "type": "string" },
        "status": { 
          "type": "string",
          "enum": ["uploading", "parsing", "extracting", "indexing", "completed", "failed"]
        },
        "progress": { "type": "number" },
        "message": { "type": "string" },
        "pageCount": { "type": "number" },
        "text": { "type": "string" },
        "chunks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "index": { "type": "number" }
            }
          }
        },
        "error": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "filename", "status"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat session associated with a document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "docId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat session",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profile data"
    },
    "/documents/{docId}": {
      "schema": "Document",
      "description": "Flattened document collection for global querying if needed, secured by userId"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages inside a chat"
    }
  }
}
